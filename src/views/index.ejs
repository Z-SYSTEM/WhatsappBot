<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= botName %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-body">
    <div class="dashboard">
        <header class="dashboard-header">
            <div class="dashboard-brand">
                <h1 class="dashboard-title"><%= botName %></h1>
                <span class="dashboard-version">
                    v<%= appVersion %>
                    <a href="/api/version" target="_blank" class="dashboard-version-link">Ver novedades</a>
                </span>
            </div>
            <a href="/logout" class="btn-session-logout">Cerrar Sesión</a>
        </header>

        <main class="dashboard-main">
            <aside class="dashboard-sidebar">
                <section class="hero-card" id="hero-section">
                    <div id="status-container" class="hero-status">
                        <div id="status-indicator" class="status-dot disconnected"></div>
                        <p id="status-text">Desconectado</p>
                    </div>
                    <div id="qr-container" class="hero-qr">
                        <p class="hero-qr-label">Escanea el código QR con WhatsApp</p>
                        <canvas id="qr-canvas"></canvas>
                    </div>
                </section>

                <section class="bot-controls">
                    <div class="actions-container">
                        <button id="btn-start-bot" class="btn-action btn-start">Iniciar Bot</button>
                        <button id="btn-stop-bot" class="btn-action btn-stop">Detener Bot</button>
                        <button id="btn-logout-whatsapp" class="btn-action btn-logout-wa">Cerrar Sesión WhatsApp</button>
                    </div>
                </section>

                <section class="send-message-container action-card">
                    <h3 class="action-card-title">Enviar Mensaje</h3>
                    <form id="send-message-form">
                        <div class="form-group">
                            <label for="send-phone">Teléfono</label>
                            <input type="text" id="send-phone" name="phone" required placeholder="5491122334455">
                        </div>
                        <div class="form-group">
                            <label for="send-message">Mensaje</label>
                            <textarea id="send-message" name="message" rows="2" required placeholder="Escribe aquí..."></textarea>
                        </div>
                        <button type="submit" class="btn-send-test">Enviar</button>
                    </form>
                    <div id="send-message-status" class="action-status"></div>
                </section>

                <section class="contact-info-container action-card">
                    <h3 class="action-card-title">Info de Contacto</h3>
                    <form id="contact-info-form">
                        <div class="form-group">
                            <label for="contact-phone">Teléfono</label>
                            <input type="text" id="contact-phone" name="phone" required placeholder="5491122334455">
                        </div>
                        <button type="submit" class="btn-send-test">Consultar</button>
                    </form>
                    <div id="contact-info-status" class="action-status"></div>
                    <div id="contact-result" class="contact-result">
                        <div class="contact-result-header">
                            <img id="contact-photo" class="contact-photo" src="" alt="Foto" onerror="this.style.display='none'">
                            <div class="contact-details">
                                <h4 id="contact-name">-</h4>
                                <div class="contact-number" id="contact-number">-</div>
                            </div>
                        </div>
                    </div>
                </section>
            </aside>

            <section class="dashboard-console">
                <div class="console-header">
                    <h2 class="console-title">Consola</h2>
                    <div class="log-filters">
                        <label class="log-filter-pill"><input type="checkbox" id="filter-info" checked> Info</label>
                        <label class="log-filter-pill"><input type="checkbox" id="filter-warn" checked> Warn</label>
                        <label class="log-filter-pill"><input type="checkbox" id="filter-error" checked> Error</label>
                        <label class="log-filter-pill"><input type="checkbox" id="filter-debug" checked> Debug</label>
                    </div>
                    <button id="btn-clear-log" class="btn-clear-log">Limpiar</button>
                </div>
                <div id="log-box" class="console-output"></div>
            </section>
        </main>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
